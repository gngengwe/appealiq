---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="ClearIQ home">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="28" height="28" rx="6" fill="#1A2535"/>
          <text x="14" y="20" text-anchor="middle" font-family="Georgia, serif" font-size="14" fill="#1A8EA8">A</text>
        </svg>
        <span class="footer-logo-name">Appeal<span class="footer-logo-iq">-IQ</span></span>
      </a>
      <p class="footer-tagline">From denial chaos to appeal-ready clarity.</p>
      <p class="footer-desc">
        An AI-assisted appeal-preparation workspace for legal-medical teams handling health insurance denials.
        Early-stage concept — not yet available.
      </p>
      <p class="footer-vision">
        Built to become the operating layer for insurance denial advocacy.
      </p>
    </div>

    <div class="footer-right">
      <div class="footer-nav-col">
        <span class="footer-nav-heading">Product</span>
        <nav aria-label="Product navigation">
          <a href="#product" class="footer-link">How It Works</a>
          <a href="#recovery-disbursement" class="footer-link">Recovery & Disbursement</a>
          <a href="#features" class="footer-link">Features</a>
          <a href="#who-for" class="footer-link">Who It's For</a>
        </nav>
      </div>
      <div class="footer-nav-col">
        <span class="footer-nav-heading">Early Access</span>
        <nav aria-label="Early access navigation">
          <a href="#early-access" class="footer-link">Join the Waitlist</a>
          <a href="#early-access" class="footer-link">Request Early Access</a>
        </nav>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {year} ClearIQ. An early-stage concept by
        <a href="https://ngengwe.com" class="footer-brand-link" target="_blank" rel="noopener noreferrer">HK Clearway</a>,
        powered by becomiNG.
      </p>
      <p class="footer-disclaimer">
        ClearIQ does not provide legal, medical, or insurance advice.
        All appeal materials require attorney or licensed professional review before use.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-dark);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    padding-top: 64px;
    padding-bottom: 52px;
    align-items: start;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    text-decoration: none;
  }

  .footer-logo-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
  }

  .footer-logo-iq {
    color: var(--teal);
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: rgba(255,255,255,0.60);
    font-style: italic;
    margin-bottom: 14px;
  }

  .footer-desc {
    font-size: 0.84rem;
    color: rgba(255,255,255,0.30);
    line-height: 1.7;
    max-width: 380px;
  }

  .footer-vision {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-style: italic;
    color: rgba(255,255,255,0.18);
    margin-top: 10px;
    max-width: 340px;
  }

  .footer-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    padding-top: 4px;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav-heading {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    margin-bottom: 2px;
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.45);
    transition: color 0.15s;
    text-decoration: none;
  }

  .footer-link:hover {
    color: rgba(255,255,255,0.80);
  }

  /* Footer bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 24px 0;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.28);
  }

  .footer-brand-link {
    color: rgba(255,255,255,0.45);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .footer-brand-link:hover {
    color: rgba(255,255,255,0.70);
  }

  .footer-disclaimer {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.20);
    max-width: 480px;
    text-align: right;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-top: 48px;
      padding-bottom: 40px;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-disclaimer {
      text-align: left;
    }
  }
</style>
