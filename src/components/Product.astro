---
const steps = [
  {
    n: "01",
    title: "Secure Intake",
    body: "Structured patient and case intake captures the information needed for a complete appeal file — consistently, across every case.",
  },
  {
    n: "02",
    title: "Denial Letter Review",
    body: "Upload the denial letter. ClearIQ extracts the denial reason, coverage language, and insurer's stated basis — ready for legal and clinical review.",
  },
  {
    n: "03",
    title: "AI-Assisted Patient Interview",
    body: "Structured interview guides and transcription tools capture patient-reported information, treatment history, and functional impact in a reviewable format.",
  },
  {
    n: "04",
    title: "Medical & Legal Fact Extraction",
    body: "Medical records, treatment notes, and physician documentation are parsed to surface clinically relevant facts mapped to the denial reason.",
  },
  {
    n: "05",
    title: "Appeal-Strength Classification",
    body: "The case is assessed for appeal viability based on denial type, supporting documentation strength, and alignment with coverage standards.",
  },
  {
    n: "06",
    title: "Missing Support Detection",
    body: "ClearIQ identifies gaps in clinical documentation, physician support, and legal argument — before the appeal is drafted.",
  },
  {
    n: "07",
    title: "Attorney & Advocate Review",
    body: "All extracted facts, arguments, and gaps are presented in a structured workspace for expert review, annotation, and decision-making.",
  },
  {
    n: "08",
    title: "Editable Appeal Package",
    body: "A complete, formatted appeal package — cover letter, argument structure, supporting documentation index — is generated for final expert review and submission.",
  },
  {
    n: "09",
    title: "Outcome & Recovery",
    body: "When the insurer approves, recovery and disbursement activates automatically — calculating fee splits, coordinating multi-party disbursements, and reconciling remittances without a separate billing workflow.",
  },
];
---

<section class="product" id="product">
  <div class="container">
    <div class="product-header">
      <span class="section-label">The Workspace</span>
      <h2 class="product-headline">
        One structured workspace.<br />
        From intake to appeal-ready.
      </h2>
      <p class="product-subhead">
        ClearIQ creates a single, structured thread from the first intake form to the final
        appeal package — so nothing is scattered, nothing is missed, and expert judgment
        can focus on what matters.
      </p>
    </div>

    <div class="product-steps">
      {steps.map((step, i) => (
        <article class="step" style={`--delay: ${i * 30}ms`}>
          <div class="step-n">{step.n}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true" />
          )}
        </article>
      ))}
    </div>

    <div class="product-note">
      <div class="product-note-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M9 2v7l4 3" stroke="#1A8EA8" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="9" cy="9" r="7.5" stroke="#1A8EA8" stroke-width="1.5"/>
        </svg>
      </div>
      <p class="product-note-text">
        Human judgment stays in control at every step. ClearIQ organizes and surfaces — attorneys and advocates decide.
      </p>
    </div>
  </div>
</section>

<style>
  .product {
    background: var(--white);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .product-header {
    max-width: 600px;
    margin-bottom: 64px;
  }

  .product-headline {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--navy-dark);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .product-subhead {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.75;
  }

  .product-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 36px;
  }

  .step {
    position: relative;
    padding: 28px 26px 32px;
    background: var(--white);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .step:nth-child(3n) {
    border-right: none;
  }

  .step:nth-child(n+7) {
    border-bottom: none;
  }

  .step:hover {
    background: var(--ivory);
  }

  .step-n {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--teal);
    margin-bottom: 14px;
  }

  .step-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--navy-dark);
    margin-bottom: 10px;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }

  .step-body {
    font-size: 0.855rem;
    color: var(--text-mid);
    line-height: 1.65;
  }

  .product-note {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 20px 24px;
    background: var(--teal-xlight);
    border: 1px solid rgba(26,142,168,0.18);
    border-radius: var(--radius-lg);
    max-width: 680px;
  }

  .product-note-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .product-note-text {
    font-size: 0.9rem;
    color: var(--navy-mid);
    line-height: 1.6;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .product-steps {
      grid-template-columns: repeat(2, 1fr);
    }

    .step:nth-child(3n) {
      border-right: 1px solid var(--border);
    }

    .step:nth-child(2n) {
      border-right: none;
    }

    .step:nth-child(n+7) {
      border-bottom: 1px solid var(--border);
    }

    .step:nth-last-child(-n+2) {
      border-bottom: none;
    }

    /* last item if odd count */
    .step:last-child {
      border-bottom: none;
      border-right: none;
    }
  }

  @media (max-width: 520px) {
    .product-steps {
      grid-template-columns: 1fr;
    }

    .step {
      border-right: none;
    }

    .step:not(:last-child) {
      border-bottom: 1px solid var(--border);
    }

    .step:last-child {
      border-bottom: none;
    }
  }
</style>
