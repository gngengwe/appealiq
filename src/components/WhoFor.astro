---
const personas = [
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><rect x="3" y="3" width="20" height="20" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M8 13h10M13 8v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    role: "OBL Owners",
    title: "Office-Based Lab Owners",
    body: "You look at the schedule and see twelve. By procedure day, half are pending auth, denied, or under appeal. You need visibility into your authorization pipeline and confidence that high-value procedures are protected — not discovered missing after the fact.",
    anchors: ["Schedule protection", "Auth pipeline oversight", "Revenue at risk dashboard"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><rect x="4" y="3" width="18" height="20" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 9h10M8 13h10M8 17h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    role: "Billing & Auth Staff",
    title: "Practice Billing &amp; Authorization Managers",
    body: "You're managing pre-certifications, tracking denial letters, and writing appeal responses by hand — alongside everything else. ClearIQ turns hours of manual letter-writing into a guided workflow so nothing gets missed and nothing waits on you alone.",
    anchors: ["Pre-cert automation", "Appeal letter generation", "Denial tracking & triage"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 4v18M4 13h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="13" cy="13" r="9" stroke="currentColor" stroke-width="1.5"/></svg>`,
    role: "Cardiologists",
    title: "Cardiologists &amp; Interventional Practices",
    body: "Atherectomy, stents, balloon angioplasty, genicular embolization, venous stents, IVUS — high-value procedures where every denied case represents real revenue. ClearIQ tracks reimbursement by procedure and insurer so you know where you stand.",
    anchors: ["Procedure-specific appeals", "Insurer reimbursement tracking", "Appeal ROI by procedure"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 3L4 7v5c0 4 3.5 7.5 7 8 3.5-.5 7-4 7-8V7L13 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 13l3 3 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    role: "Surgery Centers",
    title: "Ambulatory Surgery Centers",
    body: "Any procedure center managing prior authorizations across a high-volume caseload faces the same math: the authorization problem scales with procedure volume. ClearIQ scales with it — tracking every pending auth, every denial, every appeal across the full schedule.",
    anchors: ["Multi-procedure management", "Payer intelligence by procedure", "Volume case tracking"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><circle cx="13" cy="9" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M5 23c0-4.42 3.58-8 8-8s8 3.58 8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    role: "Specialty Practices",
    title: "Pain Management, GI &amp; Specialty Practices",
    body: "GI, pain management, neurosurgery, orthopedics — any specialty performing high-value outpatient procedures where authorization denials represent recoverable revenue. ClearIQ's coverage expands to match your procedure mix.",
    anchors: ["Specialty procedure support", "Cross-payer tracking", "Expanding procedure coverage"],
  },
];
---

<section class="whofor" id="who-for">
  <div class="container">
    <div class="whofor-header">
      <span class="section-label">Who It's For</span>
      <h2 class="whofor-headline">
        Built for the practices where<br />authorization failures cost real money.
      </h2>
      <p class="whofor-subhead">
        ClearIQ is purpose-built for OBL owners, cardiologists, and the billing teams
        managing their authorization pipeline — starting in cardiology and expanding
        to any high-value procedure practice.
      </p>
    </div>

    <div class="whofor-grid">
      {personas.map((p) => (
        <article class="persona-card">
          <div class="persona-icon-wrap">
            <div class="persona-icon" set:html={p.icon} />
            <span class="persona-role">{p.role}</span>
          </div>
          <h3 class="persona-title" set:html={p.title} />
          <p class="persona-body">{p.body}</p>
          <ul class="persona-anchors">
            {p.anchors.map((a) => (
              <li class="persona-anchor">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {a}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .whofor {
    background: var(--white);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .whofor-header {
    max-width: 620px;
    margin-bottom: 56px;
  }

  .whofor-headline {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--navy-dark);
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .whofor-subhead {
    font-size: 1.025rem;
    color: var(--text-mid);
    line-height: 1.72;
  }

  .whofor-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .persona-card {
    background: var(--ivory);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 26px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .persona-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-mid);
  }

  .persona-icon-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .persona-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--navy-mid);
    flex-shrink: 0;
  }

  .persona-role {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-dark);
  }

  .persona-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--navy-dark);
    line-height: 1.4;
    letter-spacing: -0.005em;
  }

  .persona-body {
    font-size: 0.875rem;
    color: var(--text-mid);
    line-height: 1.7;
    flex: 1;
  }

  .persona-anchors {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }

  .persona-anchor {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-mid);
  }

  .persona-anchor svg {
    color: var(--teal);
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .whofor-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .whofor-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
