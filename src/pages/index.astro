---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Scenario from '../components/Scenario.astro';
import Product from '../components/Product.astro';
import PaymentEngine from '../components/PaymentEngine.astro';
import NotJustAI from '../components/NotJustAI.astro';
import Features from '../components/Features.astro';
import WhoFor from '../components/WhoFor.astro';
import EarlyAccess from '../components/EarlyAccess.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ClearIQ — Authorization &amp; Reimbursement Platform for OBL Owners"
  description="ClearIQ automates the full authorization-to-reimbursement pipeline for OBL owners and high-value procedure practices — from pre-certification through denial, appeal, and final payment recovery."
>
  <NavBar />
  <main>
    <Hero />
    <Problem />
    <Scenario />
    <Product />
    <PaymentEngine />
    <NotJustAI />
    <Features />
    <WhoFor />
    <EarlyAccess />
  </main>
  <Footer />
</Layout>
