---
const problems = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M11 2v4M11 16v4M4.22 4.22l2.83 2.83M14.95 14.95l2.83 2.83M2 11h4M16 11h4M4.22 17.78l2.83-2.83M14.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: "Pre-Authorization Maze",
    body: "Every insurer runs a different credentialing process, requires different documentation, and applies different criteria for the same procedure. There is no standard — just a gauntlet your billing staff navigates from scratch, every time.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="8.5" stroke="currentColor" stroke-width="1.6"/><path d="M11 7v4.5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Schedule Bleeding",
    body: "You build the schedule. Then half the patients fall into authorization pending, get denied, or end up under appeal. You lose the procedure, the revenue, and the slot — before the week even starts.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><rect x="2" y="3" width="6" height="8" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="10" y="3" width="10" height="4" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="10" y="9.5" width="10" height="4" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="2" y="13" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: "Appeals Written by Hand",
    body: "Your office manager writes every appeal letter from scratch. She's managing a hundred other things and she's not an appeal specialist — she's doing this alongside everything else. The letters go out. You don't always know what happens next.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M4 17l4-4 3 3 7-9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="11" cy="4.5" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>`,
    title: "No Pipeline Visibility",
    body: "You can't see which procedures are approved, which are pending, and which are already lost — until patients are or aren't on the schedule. By then, it's too late to act.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M11 3L4 7v5c0 4 3.5 7.5 7 8 3.5-.5 7-4 7-8V7L11 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 11l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "High-Value Procedures at Risk",
    body: "Atherectomy, genicular embolization, venous stents — these procedures reimburse in the thousands per case. One denied procedure, left unappealed or appealed too late, is real revenue that doesn't come back.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M3 6h16M3 11h10M3 16h7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="17" cy="15.5" r="3.5" stroke="currentColor" stroke-width="1.4"/><path d="M17 14v1.5l1 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    title: "No Appeal Intelligence",
    body: "Which procedures appeal successfully with which insurers? Which denial reasons are worth fighting? No one knows — because nothing in your current workflow is tracking it.",
  },
];
---

<section class="problem" id="problem">
  <div class="container">
    <div class="problem-header">
      <span class="section-label">The Challenge</span>
      <h2 class="problem-headline">
        The revenue problem starts before the denial.
      </h2>
      <p class="problem-body">
        For OBL owners and high-value procedure practices, the authorization pipeline
        is where revenue is won or lost — not in the appeal letter. Your billing team
        is fighting this by hand, insurer by insurer, procedure by procedure, with no
        system built for the work.
      </p>
    </div>

    <div class="problem-grid">
      {problems.map((p) => (
        <article class="problem-card">
          <div class="problem-icon" set:html={p.icon} />
          <h3 class="problem-card-title">{p.title}</h3>
          <p class="problem-card-body">{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .problem {
    background: var(--ivory);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .problem-header {
    max-width: 640px;
    margin-bottom: 60px;
  }

  .problem-headline {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--navy-dark);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .problem-body {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.75;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .problem-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 28px 32px;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .problem-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-mid);
    transform: translateY(-2px);
  }

  .problem-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--teal-light);
    border-radius: var(--radius);
    color: var(--teal-dark);
    margin-bottom: 18px;
  }

  .problem-card-title {
    font-family: var(--font-sans);
    font-size: 0.975rem;
    font-weight: 600;
    color: var(--navy-dark);
    margin-bottom: 10px;
    letter-spacing: -0.005em;
  }

  .problem-card-body {
    font-size: 0.9rem;
    color: var(--text-mid);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .problem-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
