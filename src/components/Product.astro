---
const steps = [
  {
    n: "01",
    title: "Pre-Certification Filing",
    body: "Know what each insurer requires for each procedure before you file. Requirement templates by payer and procedure type reduce first-denial rates and protect your schedule.",
  },
  {
    n: "02",
    title: "Auth Status Dashboard",
    body: "Real-time visibility into every pending authorization: approved, at-risk, or denied. See what's happening to your schedule before it's too late to act.",
  },
  {
    n: "03",
    title: "Denial Detection & Triage",
    body: "When authorization fails, the denial is automatically captured, classified by reason, and queued for appeal — no manual monitoring, no missed windows.",
  },
  {
    n: "04",
    title: "Insurer Coverage Analysis",
    body: "The denial reason and insurer-specific coverage language are parsed to identify exactly what documentation is needed to reverse the decision.",
  },
  {
    n: "05",
    title: "Clinical Documentation Review",
    body: "Medical records, procedure notes, and supporting clinical evidence are organized around the specific denial basis — not generic documentation, denial-specific.",
  },
  {
    n: "06",
    title: "Physician Support Gap Detection",
    body: "Missing, incomplete, or clinically misaligned documentation is flagged before the appeal is drafted — so nothing critical is left out of the submission.",
  },
  {
    n: "07",
    title: "Appeal Letter Generation",
    body: "A procedure-specific appeal letter is generated from the denial reason, clinical evidence, and insurer's coverage standards — ready for review in minutes, not drafted from scratch.",
  },
  {
    n: "08",
    title: "Appeal Package Builder",
    body: "Complete, formatted submission package: cover letter, clinical argument, supporting documentation index — ready to submit to the insurer.",
  },
  {
    n: "09",
    title: "Recovery & Reimbursement",
    body: "When the insurer approves, reimbursement tracking activates — logging the approved amount, reconciling remittances, and closing the case in your practice ledger.",
  },
];
---

<section class="product" id="product">
  <div class="container">
    <div class="product-header">
      <span class="section-label">The Pipeline</span>
      <h2 class="product-headline">
        One platform.<br />
        From pre-auth to final payment.
      </h2>
      <p class="product-subhead">
        ClearIQ manages the full authorization-to-reimbursement lifecycle — from the
        moment a procedure is scheduled through pre-certification, denial, appeal,
        and final payment recovery. Nothing falls through between steps.
      </p>
    </div>

    <div class="product-steps">
      {steps.map((step, i) => (
        <article class="step" style={`--delay: ${i * 30}ms`}>
          <div class="step-n">{step.n}</div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true" />
          )}
        </article>
      ))}
    </div>

    <div class="product-note">
      <div class="product-note-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M9 2v7l4 3" stroke="#1A8EA8" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="9" cy="9" r="7.5" stroke="#1A8EA8" stroke-width="1.5"/>
        </svg>
      </div>
      <p class="product-note-text">
        Human judgment stays in control at every step. ClearIQ prepares and automates — your team reviews and approves.
      </p>
    </div>
  </div>
</section>

<style>
  .product {
    background: var(--white);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .product-header {
    max-width: 600px;
    margin-bottom: 64px;
  }

  .product-headline {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--navy-dark);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .product-subhead {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.75;
  }

  .product-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 36px;
  }

  .step {
    position: relative;
    padding: 28px 26px 32px;
    background: var(--white);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .step:nth-child(3n) {
    border-right: none;
  }

  .step:nth-child(n+7) {
    border-bottom: none;
  }

  .step:hover {
    background: var(--ivory);
  }

  .step-n {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--teal);
    margin-bottom: 14px;
  }

  .step-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--navy-dark);
    margin-bottom: 10px;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }

  .step-body {
    font-size: 0.855rem;
    color: var(--text-mid);
    line-height: 1.65;
  }

  .product-note {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 20px 24px;
    background: var(--teal-xlight);
    border: 1px solid rgba(26,142,168,0.18);
    border-radius: var(--radius-lg);
    max-width: 680px;
  }

  .product-note-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .product-note-text {
    font-size: 0.9rem;
    color: var(--navy-mid);
    line-height: 1.6;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .product-steps {
      grid-template-columns: repeat(2, 1fr);
    }

    .step:nth-child(3n) {
      border-right: 1px solid var(--border);
    }

    .step:nth-child(2n) {
      border-right: none;
    }

    .step:nth-child(n+7) {
      border-bottom: 1px solid var(--border);
    }

    .step:nth-last-child(-n+2) {
      border-bottom: none;
    }

    /* last item if odd count */
    .step:last-child {
      border-bottom: none;
      border-right: none;
    }
  }

  @media (max-width: 520px) {
    .product-steps {
      grid-template-columns: 1fr;
    }

    .step {
      border-right: none;
    }

    .step:not(:last-child) {
      border-bottom: 1px solid var(--border);
    }

    .step:last-child {
      border-bottom: none;
    }
  }
</style>
