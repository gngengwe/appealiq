          Do not share publicly.
        </p>
      </section>

    </div>
  </div>
</div>

</Layout>

<style>
  /* ─── Internal Banner ─────────────────────────── */
  .internal-banner {
    background: #1A2535;
    padding: 12px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .banner-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .banner-logo-name {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.01em;
  }

  .banner-logo-iq { color: var(--teal); }

  .banner-badge {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.30);
