---
const personas = [
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 3C9.13 3 6 6.13 6 10c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="13" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
    role: "Attorneys",
    title: "Health Insurance Defense & Appeal Counsel",
    body: "Attorneys managing appeal caseloads need faster fact organization, structured documentation review, and editable draft output — without sacrificing the analytical judgment that wins appeals.",
    anchors: ["Case management", "Legal argument development", "Expert review workspace"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><circle cx="13" cy="9" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M5 23c0-4.42 3.58-8 8-8s8 3.58 8 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    role: "Patient Advocates",
    title: "Health Insurance Patient Advocates",
    body: "Advocates working on behalf of patients need a structured way to capture intake, gather medical evidence, and prepare complete appeal submissions — without an attorney's office behind them.",
    anchors: ["Structured intake", "Documentation support", "Guided appeal workflow"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><rect x="4" y="3" width="18" height="20" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 9h10M8 13h10M8 17h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    role: "Appeal Specialists",
    title: "Healthcare Appeal Specialists",
    body: "Appeal specialists handling high-volume denial management need repeatable workflows, denial reason classification, and structured output that scales across case types and insurers.",
    anchors: ["Denial classification", "Repeatable workflow", "Volume case management"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 3l2.5 5.5L21 9.5l-4 4 .5 5.5L13 16.5 8.5 19l.5-5.5L5 9.5l5.5-1L13 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    role: "Case Managers",
    title: "Legal-Medical Case Managers",
    body: "Case managers coordinating between patients, physicians, and legal teams need a shared workspace that keeps everyone aligned — from intake through final submission.",
    anchors: ["Cross-team coordination", "Physician support tracking", "Submission readiness"],
  },
  {
    icon: `<svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true"><path d="M13 4v18M4 13h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="13" cy="13" r="9" stroke="currentColor" stroke-width="1.5"/></svg>`,
    role: "Clinical Support",
    title: "Clinical Support Teams",
    body: "Clinical staff supporting appeal efforts need structured templates and clear documentation guidance to ensure physician letters and clinical records are aligned with the specific denial being appealed.",
    anchors: ["Clinical documentation", "Physician letter support", "Denial alignment"],
  },
];
---

<section class="whofor" id="who-for">
  <div class="container">
    <div class="whofor-header">
      <span class="section-label">Who It's For</span>
      <h2 class="whofor-headline">
        Built for the people who turn<br />insurance denials into appeal packages.
      </h2>
      <p class="whofor-subhead">
        ClearIQ is purpose-built for legal-medical professionals who work under deadline pressure
        with fragmented materials and high stakes.
      </p>
    </div>

    <div class="whofor-grid">
      {personas.map((p) => (
        <article class="persona-card">
          <div class="persona-icon-wrap">
            <div class="persona-icon" set:html={p.icon} />
            <span class="persona-role">{p.role}</span>
          </div>
          <h3 class="persona-title">{p.title}</h3>
          <p class="persona-body">{p.body}</p>
          <ul class="persona-anchors">
            {p.anchors.map((a) => (
              <li class="persona-anchor">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {a}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .whofor {
    background: var(--white);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .whofor-header {
    max-width: 620px;
    margin-bottom: 56px;
  }

  .whofor-headline {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--navy-dark);
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .whofor-subhead {
    font-size: 1.025rem;
    color: var(--text-mid);
    line-height: 1.72;
  }

  .whofor-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .persona-card {
    background: var(--ivory);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 26px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .persona-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-mid);
  }

  .persona-icon-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .persona-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--navy-mid);
    flex-shrink: 0;
  }

  .persona-role {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-dark);
  }

  .persona-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--navy-dark);
    line-height: 1.4;
    letter-spacing: -0.005em;
  }

  .persona-body {
    font-size: 0.875rem;
    color: var(--text-mid);
    line-height: 1.7;
    flex: 1;
  }

  .persona-anchors {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }

  .persona-anchor {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-mid);
  }

  .persona-anchor svg {
    color: var(--teal);
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .whofor-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .whofor-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
