---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M7 8h10M7 11h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 21l4-4 4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Pre-Authorization Intelligence",
    badge: "Pre-Cert",
    body: "Know exactly what each insurer requires for each procedure before you file. Payer-specific requirement templates reduce first-denial rates and protect your schedule from avoidable authorization failures.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3L3 7.5v9L12 21l9-4.5v-9L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="12" r="2.5" fill="currentColor" opacity="0.4"/><path d="M12 9.5v-4M12 18.5v-4M6.5 14.5L3 12.5M21 12.5l-3.5 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    title: "Appeal Strength Analysis",
    badge: "Analysis",
    body: "Every denial is assessed for appeal viability across denial type, clinical documentation strength, and insurer coverage argument — giving your team a clear read before committing time and resources.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M7 8h10M7 11h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="17" cy="17" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M15.5 17h3M17 15.5v3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>`,
    title: "Denial Reason Interpreter",
    badge: "Extraction",
    body: "Denial letters are parsed to extract the exact coverage basis, policy language cited, and clinical criteria applied — translating insurance-speak into structured, actionable information your team can act on.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/></svg>`,
    title: "Physician Support Gap Detector",
    badge: "Gap Analysis",
    body: "Missing, incomplete, or clinically misaligned documentation is flagged before the appeal is drafted — with structured prompts identifying exactly what's needed and why it matters for the specific denial.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 17l4-8 4 5 2-3 4 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><rect x="2" y="2" width="20" height="20" rx="2.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "Reimbursement Intelligence",
    badge: "Analytics",
    body: "Procedure-by-procedure, insurer-by-insurer tracking of what you're receiving vs. what you should be — and which appeal efforts are yielding the highest return. Know where to focus and where to let go.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8L14 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    title: "Appeal Package Builder",
    badge: "Output",
    body: "A complete, formatted appeal package — cover letter, clinical argument, supporting documentation index — generated for review and submission. Submission-ready, not a rough draft.",
  },
];
---

<section class="features" id="features">
  <div class="container">
    <div class="features-header">
      <span class="section-label">Core Features</span>
      <h2 class="features-headline">
        Built for the full authorization pipeline.
      </h2>
      <p class="features-subhead">
        Six purpose-built modules that take a procedure from pre-certification
        through denial, appeal, and reimbursement recovery — with human review at every step.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <article class="feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <div class="feature-meta">
            <span class="feature-badge">{f.badge}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-body">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--ivory);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .features-header {
    max-width: 580px;
    margin-bottom: 52px;
  }

  .features-headline {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--navy-dark);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .features-subhead {
    font-size: 1.025rem;
    color: var(--text-mid);
    line-height: 1.72;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: rgba(26,142,168,0.25);
    transform: translateY(-3px);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: var(--navy-dark);
    border-radius: var(--radius);
    color: var(--teal);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .feature-meta {
    margin-bottom: 10px;
  }

  .feature-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-dark);
    background: var(--teal-light);
    padding: 3px 9px;
    border-radius: 100px;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--navy-dark);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }

  .feature-body {
    font-size: 0.875rem;
    color: var(--text-mid);
    line-height: 1.7;
    flex: 1;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
