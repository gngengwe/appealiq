---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3L3 7.5v9L12 21l9-4.5v-9L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="12" r="2.5" fill="currentColor" opacity="0.4"/><path d="M12 9.5v-4M12 18.5v-4M6.5 14.5L3 12.5M21 12.5l-3.5 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    title: "Appeal Strength Map",
    badge: "Analysis",
    body: "Every case is assessed for appeal viability across denial type, clinical documentation quality, insurer argument, and applicable coverage standards — giving teams a structured read before committing resources.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M7 8h10M7 11h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 21l4-4 4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Denial Reason Interpreter",
    badge: "Extraction",
    body: "Denial letters are parsed to extract the insurer's stated basis, coverage language cited, and specific policy provisions invoked — translating insurance-speak into structured, actionable review.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/></svg>`,
    title: "Physician Support Gap Detector",
    badge: "Gap Analysis",
    body: "Missing, incomplete, or clinically misaligned physician letters are flagged before drafting begins — with structured prompts identifying what documentation is needed and why.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><ellipse cx="12" cy="19" rx="7" ry="2" stroke="currentColor" stroke-width="1.4" opacity="0.35"/><path d="M5 19V8l7-5 7 5v11" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 19v-5h6v5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
    title: "Historical Appeal Memory",
    badge: "Institutional Knowledge",
    body: "Winning arguments, effective physician letter structures, and denial-specific strategies from past cases inform future case preparation — without reinventing the wheel every time.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="9" cy="7" r="3.5" stroke="currentColor" stroke-width="1.6"/><path d="M3 20c0-3.3 2.7-6 6-6h0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16 13l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="19" cy="16" r="4.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: "Attorney Review Workspace",
    badge: "Expert Review",
    body: "Extracted facts, argument themes, documentation gaps, and generated drafts are presented in a structured workspace designed for attorney and advocate review, annotation, and decision-making.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8L14 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    title: "Appeal Package Builder",
    badge: "Output",
    body: "A complete, formatted appeal package — cover letter, argument structure, clinical documentation summary, and supporting exhibit index — generated for final expert review and submission.",
  },
];
---

<section class="features" id="features">
  <div class="container">
    <div class="features-header">
      <span class="section-label">Core Features</span>
      <h2 class="features-headline">
        Built for the full appeal workflow.
      </h2>
      <p class="features-subhead">
        Six purpose-built modules that take a case from denial intake to submission-ready
        appeal package — with expert review at the center.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <article class="feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <div class="feature-meta">
            <span class="feature-badge">{f.badge}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-body">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--ivory);
    padding: var(--section-y) 0;
    border-top: 1px solid var(--border);
  }

  .features-header {
    max-width: 580px;
    margin-bottom: 52px;
  }

  .features-headline {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--navy-dark);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .features-subhead {
    font-size: 1.025rem;
    color: var(--text-mid);
    line-height: 1.72;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: rgba(26,142,168,0.25);
    transform: translateY(-3px);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: var(--navy-dark);
    border-radius: var(--radius);
    color: var(--teal);
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .feature-meta {
    margin-bottom: 10px;
  }

  .feature-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-dark);
    background: var(--teal-light);
    padding: 3px 9px;
    border-radius: 100px;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--navy-dark);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }

  .feature-body {
    font-size: 0.875rem;
    color: var(--text-mid);
    line-height: 1.7;
    flex: 1;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
